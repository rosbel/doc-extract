# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/extraction_service

# Redis
REDIS_URL=redis://localhost:6379

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Pinecone (optional - vector search disabled if not set)
PINECONE_API_KEY=
PINECONE_INDEX=document-extraction

# Server
PORT=3001
NODE_ENV=development

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
