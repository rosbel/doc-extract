# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/extraction_service

# Redis
REDIS_URL=redis://localhost:6379

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Pinecone (optional - vector search disabled if not set)
PINECONE_API_KEY=
PINECONE_INDEX=document-extraction

# Server
PORT=3001
NODE_ENV=development
ADMIN_TOKEN=change-me
ADMIN_MAX_FAILED_ATTEMPTS=5
ADMIN_LOCKOUT_MS=900000
ADMIN_FAILURE_WINDOW_MS=600000

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
